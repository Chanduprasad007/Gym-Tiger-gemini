{
  "entities": {
    "user": {
      "title": "User Profile",
      "description": "User statistics and training preferences",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The unique user ID" },
        "email": { "type": "string", "description": "User email address" },
        "displayName": { "type": "string", "description": "User's public name" },
        "streak": { "type": "integer", "description": "Current workout consecutive day streak" },
        "totalWorkouts": { "type": "integer", "description": "Total workouts logged" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last updated timestamp" }
      },
      "required": ["userId", "email", "streak", "totalWorkouts", "updatedAt"]
    },
    "workoutLog": {
      "title": "Workout Log",
      "description": "A historic record of a completed training session",
      "type": "object",
      "properties": {
        "logId": { "type": "string", "description": "Unique log identifier" },
        "userId": { "type": "string", "description": "User identifier who performed the workout" },
        "workoutName": { "type": "string", "description": "Name of the workout session" },
        "dayIndex": { "type": "integer", "description": "Day of the hypertrophy split (0 to 5)" },
        "completedAt": { "type": "string", "format": "date-time", "description": "Completion timestamp" },
        "duration": { "type": "integer", "description": "Workout duration in seconds" },
        "exercises": {
          "type": "array",
          "description": "List of exercises performed with custom weight and reps per set"
        }
      },
      "required": ["logId", "userId", "workoutName", "dayIndex", "completedAt", "duration", "exercises"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "user",
      "description": "User profiles with training metrics"
    },
    "/users/{userId}/workouts/{logId}": {
      "schema": "workoutLog",
      "description": "Workout session historic logs for each user"
    }
  }
}
